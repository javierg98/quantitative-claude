# Economic Data APIs (all free registration)
FRED_API_KEY=           # fred.stlouisfed.org (free)
BEA_API_KEY=            # apps.bea.gov/api/signup (free)
BLS_API_KEY=            # data.bls.gov/registrationEngine (free)

# No keys needed for: Yahoo Finance (FX + equities + commodities), World Bank, IMF, Zillow CSV

# App Config
NEXT_PUBLIC_APP_URL=http://localhost:3000
CRON_SECRET=your-random-secret-here

# Agent Controls
IMPROVEMENT_LOOP_ENABLED=true
HEALING_ENABLED=true

# No ANTHROPIC_API_KEY required — Claude Code CLI uses ~/.claude/credentials.json
